<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authorization Consent</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@800;900&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0a0a0f;
        --surface: #111118;
        --surface-2: #16161f;
        --border: #1e1e2e;
        --border-hi: #2e2e42;
        --accent: #c8f135;
        --accent-dim: #8aaa20;
        --accent-glow: rgba(200, 241, 53, 0.18);
        --muted: #3a3a52;
        --text: #e8e8f0;
        --text-dim: #6b6b8a;
        --danger: #ff5c5c;
        --danger-glow: rgba(255, 92, 92, 0.12);
        --radius: 6px;
      }

      ::-webkit-scrollbar {
        width: 5px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--muted);
        border-radius: 3px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: "Space Mono", monospace;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        -webkit-font-smoothing: antialiased;
        position: relative;
        overflow: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--border) 1px, transparent 1px),
          linear-gradient(90deg, var(--border) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.3;
        pointer-events: none;
      }

      .orb {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        filter: blur(80px);
      }
      .orb-1 {
        width: 500px;
        height: 500px;
        top: -180px;
        left: -100px;
        background: radial-gradient(
          circle,
          rgba(200, 241, 53, 0.07),
          transparent 65%
        );
      }
      .orb-2 {
        width: 400px;
        height: 400px;
        bottom: -120px;
        right: -80px;
        background: radial-gradient(
          circle,
          rgba(200, 241, 53, 0.05),
          transparent 65%
        );
      }

      /* ── Card ── */
      .card {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 460px;
        background: var(--surface);
        border: 1px solid var(--border-hi);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        box-shadow:
          0 0 0 1px rgba(200, 241, 53, 0.04),
          0 40px 80px rgba(0, 0, 0, 0.6);
        animation: cardIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 24px;
        right: 24px;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--accent),
          transparent
        );
        border-radius: 0 0 2px 2px;
        opacity: 0.7;
      }

      @keyframes cardIn {
        from {
          opacity: 0;
          transform: translateY(24px) scale(0.98);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      /* ── Header ── */
      .header {
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--border);
        animation: fadeDown 0.5s 0.1s ease both;
      }

      h1 {
        font-family: "Space Mono", monospace;
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.01em;
        line-height: 1.3;
        color: var(--text);
      }

      .subtitle {
        margin-top: 5px;
        font-size: 11px;
        color: var(--text-dim);
        letter-spacing: 0.03em;
        line-height: 1.6;
      }

      /* ── App Box ── */
      .app-box {
        background: var(--surface-2);
        border: 1px solid var(--border-hi);
        border-radius: var(--radius);
        padding: 1rem 1.1rem;
        margin-bottom: 1.25rem;
        animation: fadeUp 0.5s 0.18s ease both;
      }

      .app-box-label {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 0.5rem;
      }

      .app-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.01em;
        margin-bottom: 0.55rem;
      }

      .app-meta {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .app-meta-row {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        font-size: 10px;
        color: var(--text-dim);
        letter-spacing: 0.04em;
        line-height: 1.5;
      }

      .app-meta-key {
        color: var(--muted);
        white-space: nowrap;
        flex-shrink: 0;
      }

      .app-meta-val {
        color: var(--text-dim);
        word-break: break-all;
      }

      /* ── Permissions ── */
      .permissions {
        margin-bottom: 1.5rem;
        animation: fadeUp 0.5s 0.22s ease both;
      }

      .permissions-label {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 0.65rem;
      }

      .perm-list {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        list-style: none;
        padding: 0;
      }

      .perm-list li {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 11px;
        color: var(--text);
        letter-spacing: 0.02em;
      }

      .perm-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
        box-shadow: 0 0 6px rgba(200, 241, 53, 0.5);
      }

      /* ── Actions ── */
      .actions {
        display: flex;
        gap: 0.75rem;
        animation: fadeUp 0.5s 0.27s ease both;
      }

      .actions form {
        flex: 1;
        display: flex;
      }

      button {
        flex: 1;
        height: 42px;
        font-family: "Space Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        border: none;
        border-radius: var(--radius);
        cursor: pointer;
        transition:
          background 0.15s,
          box-shadow 0.15s,
          transform 0.1s;
        position: relative;
        overflow: hidden;
      }

      button::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.1) 0%,
          transparent 60%
        );
        pointer-events: none;
      }

      .approve {
        background: var(--accent);
        color: var(--bg);
      }

      .approve:hover {
        background: #d4f547;
        box-shadow: 0 0 20px rgba(200, 241, 53, 0.35);
        transform: translateY(-1px);
      }

      .approve:active {
        transform: translateY(0);
      }

      .deny {
        background: var(--surface-2);
        color: var(--text-dim);
        border: 1px solid var(--border-hi);
      }

      .deny:hover {
        background: var(--border-hi);
        color: var(--text);
        transform: translateY(-1px);
      }

      .deny:active {
        transform: translateY(0);
      }

      /* ── Animations ── */
      @keyframes fadeDown {
        from {
          opacity: 0;
          transform: translateY(-10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </head>
  <body>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="card">
      <div class="header">
        <h1>Authorize Application</h1>
        <p class="subtitle">
          The application below is requesting access to your account.
        </p>
      </div>

      <div class="app-box">
        <div class="app-box-label">Requesting Client</div>
        <div class="app-name"><%= client.name %></div>
        <div class="app-meta">
          <div class="app-meta-row">
            <span class="app-meta-key">Client ID</span>
            <span class="app-meta-val"><%= client.clientId %></span>
          </div>
          <div class="app-meta-row">
            <span class="app-meta-key">Redirect&nbsp;URI</span>
            <span class="app-meta-val"><%= client.redirectUri %></span>
          </div>
        </div>
      </div>

      <div class="permissions">
        <div class="permissions-label">Requested permissions</div>
        <ul class="perm-list">
          <li><span class="perm-dot"></span>Access your basic profile</li>
          <li><span class="perm-dot"></span>Read your email address</li>
          <li><span class="perm-dot"></span>Maintain access on your behalf</li>
        </ul>
      </div>

      <div class="actions">
        <form action="/oauth/code" method="POST">
          <input type="hidden" name="approved" value="true" />
          <button type="submit" class="approve">Allow</button>
        </form>
        <form action="/oauth/deny" method="POST">
          <button type="submit" class="deny">Deny</button>
        </form>
      </div>
    </div>
  </body>
</html>
